# Future sync provider: local | supabase | firebase | dotnet
VITE_SYNC_PROVIDER="local"
VITE_SYNC_ENABLED="false"

# Supabase, later
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Firebase, later
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# .NET API, later
VITE_API_BASE_URL=""

# Monitoring, later
VITE_SENTRY_DSN=""

# Netlify context helper
VITE_NETLIFY_SITE_URL=""
