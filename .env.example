# App
VITE_APP_NAME="Gestion dépense"
VITE_APP_VERSION="0.1.0"
VITE_APP_LOCALE="fr-FR"
VITE_APP_CURRENCY="EUR"

# Local-first storage
VITE_STORAGE_DRIVER="localStorage"
VITE_STORAGE_PREFIX="gestion-depense"
